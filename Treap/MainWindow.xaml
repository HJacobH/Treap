<Window x:Class="Treap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Treap"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Ovládání parkoviště" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <TextBlock Text="Podlaží:" />
            <ComboBox x:Name="CmbFloors" SelectedIndex="0" Margin="0,0,0,10">
                <ComboBoxItem Content="Podlaží 1"/>
                <ComboBoxItem Content="Podlaží 2"/>
                <ComboBoxItem Content="Podlaží 3"/>
                <ComboBoxItem Content="Podlaží 4"/>
            </ComboBox>

            <TextBlock Text="Číslo místa (Klíč):" />
            <TextBox x:Name="TxtSpotNumber" Margin="0,0,0,10" Padding="2"/>

            <TextBlock Text="SPZ vozidla:" />
            <TextBox x:Name="TxtLicensePlate" Margin="0,0,0,5" Padding="2"/>

            <TextBlock Text="Jméno majitele:" />
            <TextBox x:Name="TxtOwnerName" Margin="0,0,0,15" Padding="2"/>

            <Button x:Name="BtnOccupy" Content="Obsadit místo" Margin="0,0,0,5" Padding="5" Click="BtnOccupy_Click"/>
            <Button x:Name="BtnFree" Content="Uvolnit místo" Margin="0,0,0,5" Padding="5" Click="BtnFree_Click"/>
            <Button x:Name="BtnCheck" Content="Zkontrolovat obsazenost" Margin="0,0,0,5" Padding="5" Click="BtnCheck_Click"/>
            <Button x:Name="BtnNearest" Content="Najít nejbližší volné" Margin="0,0,0,15" Padding="5" Click="BtnNearest_Click"/>
            <Button x:Name="BtnPrint" Content="Vypsat všechna místa do logu" Margin="0,0,0,15" Padding="5" Click="BtnPrint_Click"/>
            
            <Separator Margin="0,10"/>

            <Button x:Name="BtnLoadFile" Content="Načíst testovací data" Padding="5" Margin="0,0,0,5" Click="BtnLoadFile_Click"/>
            <Button x:Name="BtnSaveFile" Content="Uložit data do souboru" Padding="5" Click="BtnSaveFile_Click"/>
        </StackPanel>

        <Grid Grid.Column="1" Margin="10,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Stav parkovacích míst na podlaží:" FontWeight="Bold" Margin="0,0,0,5"/>

                <ListBox Grid.Row="1" x:Name="LstOccupiedSpots" 
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Výstup / Log:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>

        <GroupBox Grid.Column="2" Header="Vizualizace Treapu (Rotace)">
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="CanvasTree" Background="WhiteSmoke" Width="1000" Height="700"/>
            </Viewbox>
        </GroupBox>
    </Grid>
</Window>
